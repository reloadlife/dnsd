# /etc/dnsd/dnsd.env — production example (do not commit real secrets)

# Control API (prefer loopback + reverse proxy, or enable TLS flags)
DNSD_LISTEN=127.0.0.1:51920
DNSD_TOKEN=replace-with-long-random-secret

# DNS data plane
DNSD_DNS_LISTEN=127.0.0.1:5353
# Production example: 0.0.0.0:53 (requires CAP_NET_BIND_SERVICE)

# Upstreams (dns / tls:// / https://)
DNSD_UPSTREAM=1.1.1.1:53,https://1.1.1.1/dns-query

# Outbound path for recursive queries
# DNSD_BIND_IP=192.168.20.6
# DNSD_BIND_IFACE=wg0

# Durable state (rules, profiles, config)
DNSD_STATE_FILE=/var/lib/dnsd/state.json

# Optional control API TLS
# DNSD_TLS_CERT=/etc/dnsd/tls.crt
# DNSD_TLS_KEY=/etc/dnsd/tls.key

# Dev only — never in production
# DNSD_ALLOW_INSECURE=false
